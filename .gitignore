# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
*.egg-info/
.eggs/

# ============================================================
# 虚拟环境
# ============================================================
venv/
env/
.venv/
ENV/

# ============================================================
# IDE / 编辑器
# ============================================================
.idea/
.vscode/
*.swp
*~

# ============================================================
# 操作系统
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# 测试 / 覆盖率
# ============================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# ============================================================
# ODPlatform 专属(Stage 1 Monorepo 路径)
# ============================================================

# 数据集不进 git(走外部存储或 Git LFS)
data/raw/
data/processed/
!data/README.md
!data/.gitkeep

# 模型权重不进 git
models/pretrained/*.pt
models/trained/*.pt
models/trained/*/
!models/pretrained/README.md
!models/trained/README.md

# 训练运行结果(每次自动产生新目录)
runs/*
!runs/README.md

# 端私有日志(运行时产生,各机器不同)
apps/platform/logging/
*.log
apps/platform/configs/
*.yaml

# 临时文件
tmp/
temp/

# ============================================================
# 大文件 / 二进制
# ============================================================
*.pkl
*.h5
*.npz
